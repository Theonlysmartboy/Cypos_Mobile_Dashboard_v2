<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.fragment.customer.TotalInvoicePerMonthFragment"
    android:orientation="vertical"
    android:id="@+id/parentContainer">
    <TextView
        android:id="@+id/spinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/client"
        android:textAlignment="center"
        android:layout_gravity="center"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginStart="@dimen/margin_lg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/client"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <Spinner
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/client"
        android:layout_gravity="center"
        android:layout_marginStart="@dimen/margin_md"
        app:layout_constraintTop_toBottomOf="@+id/spinner"
        app:layout_constraintBottom_toTopOf="@+id/invoiceHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:id="@+id/invoiceHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        android:text="@string/total_invoice_per_month"
        app:layout_constraintTop_toBottomOf="@+id/client"
        app:layout_constraintBottom_toTopOf="@+id/invoiceCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/salesHeader" />
    <TextView
        android:id="@+id/salesHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        android:text="@string/total_sales_customer_wise"
        app:layout_constraintTop_toBottomOf="@+id/client"
        app:layout_constraintBottom_toTopOf="@id/salesCount"
        app:layout_constraintStart_toEndOf="@+id/invoiceHeader"
        app:layout_constraintEnd_toEndOf="parent" />
    <TextView
        android:id="@+id/invoiceCount"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:layout_marginStart="64dp"
        app:layout_constraintTop_toBottomOf="@+id/invoiceHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/salesCount"
            android:text="@string/zero"
            android:textStyle="bold|italic"
            android:textSize="18sp"
            android:textColor="@color/colorPrimary"/>
    <TextView
        android:id="@+id/salesCount"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:layout_marginStart="64dp"
        app:layout_constraintTop_toBottomOf="@id/invoiceHeader"
        app:layout_constraintStart_toEndOf="@id/invoiceCount"
        app:layout_constraintEnd_toEndOf="parent"
            android:textStyle="bold|italic"
            android:textSize="18sp"
            android:textColor="@color/colorPrimary"/>

</androidx.constraintlayout.widget.ConstraintLayout>