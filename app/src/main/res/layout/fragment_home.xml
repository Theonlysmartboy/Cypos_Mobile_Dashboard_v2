<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1976D2"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/storeName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/kanyauyoma_traders"
                android:textSize="20sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:gravity="start"
                android:textColor="#FFFFFF" />
            <Spinner
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:id="@+id/branchSelector"/>

        </LinearLayout>

        <!-- Date Range Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_md"
                android:layout_weight="1"
                android:minHeight="48dp">
                <EditText
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/fromDateEditText"
                    android:hint="@string/date_from"
                    android:shadowRadius="10"
                    android:ems="10"
                    android:textColor="@color/colorPrimary"
                    android:textColorHint="@color/colorPrimary"
                    android:drawablePadding="@dimen/margin"
                    android:drawableStart="@drawable/ic_baseline_calendar_today_24"
                    android:autofillHints="@string/date_from"
                    android:fontFamily="@font/iceland"
                    android:inputType="date"
                    android:focusable="false"
                    android:minHeight="48dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_md"
                android:layout_weight="1"
                android:minHeight="48dp">
                <EditText
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/toDateEditText"
                    android:hint="@string/date_to"
                    android:shadowRadius="10"
                    android:ems="10"
                    android:textColor="@color/colorPrimary"
                    android:textColorHint="@color/colorPrimary"
                    android:drawablePadding="@dimen/margin"
                    android:drawableStart="@drawable/ic_baseline_calendar_today_24"
                    android:autofillHints="@string/date_to"
                    android:fontFamily="@font/iceland"
                    android:inputType="date"
                    android:focusable="false"
                    android:minHeight="48dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/refreshButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/refresh"
                android:background="@drawable/rounded_yellow_button"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!-- Dashboard Layout -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/dashboardRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_dashboard_card" />

    </LinearLayout>
</ScrollView>
